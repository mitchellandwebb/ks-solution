{
 "compilerOptions": {
    "module": "ES2015",
    "jsx": "preserve",
    "moduleResolution": "node",
    
    "strict": true,
    "alwaysStrict": true,
    "allowSyntheticDefaultImports": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noImplicitThis": false,
    "skipLibCheck": true,
    "checkJs": false,
    "lib": [ "ES2016"],
    
    "noEmit": false,
    "noEmitOnError": true,
    "outDir": "dist/js",
    "outFile": null,
    "rootDirs": ["src"]
  },
  "exclude": ["node_modules", "**/node_modules/*"],
  "include": ["src/**/*"],
}